{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["constraints", "classes"],
  "additionalProperties": false,

  "properties": {
    "constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["constraint_type", "sequence"],
        "additionalProperties": false,

        "properties": {
          "constraint_type": {
            "type": "string",
            "enum": [
              "minimize_gaps",
              "group_preference",
              "lecturer_preference",
              "maximize_single_attendance",
              "maximize_total_attendance",
              "time_block",
              "prefer_edge_classes"
            ]
          },

          "sequence": {
            "type": "integer",
            "minimum": 0
          },

          "weight": {
            "type": "number",
            "minimum": 0
          },

          "hard": {
            "type": "boolean"
          },

          "class_id": {
            "type": "string"
          },

          "min_break_duration": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1440
          },

          "preferred_group": {
            "type": "integer"
          },

          "preferred_lecturer": {
            "type": "string"
          },

          "day": {
            "type": "integer",
            "minimum": 0,
            "maximum": 6
          },

          "date": {
            "type": "string",
            "format": "date"
          },

          "start_time": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1440
          },

          "end_time": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1440
          },

          "position": {
            "type": "string",
            "enum": ["start", "end"]
          }
        },

        "allOf": [
          {
            "if": {
              "properties": { "type": { "const": "minimize_gaps" } }
            },
            "then": {
              "required": ["min_break_duration"]
            }
          },
          {
            "if": {
              "properties": { "type": { "const": "group_preference" } }
            },
            "then": {
              "required": ["class_id", "preferred_group"]
            }
          },
          {
            "if": {
              "properties": { "type": { "const": "lecturer_preference" } }
            },
            "then": {
              "required": ["class_id", "preferred_lecturer"]
            }
          },
          {
            "if": {
              "properties": { "type": { "const": "maximize_single_attendance" } }
            },
            "then": {
              "required": ["class_id"]
            }
          },
          {
            "if": {
              "properties": { "type": { "const": "time_block" } }
            },
            "then": {
              "required": ["start_time", "end_time"],
              "anyOf": [
                { "required": ["day"] },
                { "required": ["date"] }
              ]
            }
          },
          {
            "if": {
              "properties": { "type": { "const": "prefer_edge_classes" } }
            },
            "then": {
              "required": ["class_id", "position"]
            }
          }
        ]
      }
    },

    "classes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "lecturer",
          "day",
          "week",
          "location",
          "group",
          "class_type",
          "start_time",
          "end_time",
          "sessions"
        ],
        "additionalProperties": false,

        "properties": {
          "id": {
            "type": "string"
          },

          "lecturer": {
            "type": "string"
          },

          "day": {
            "type": "integer",
            "minimum": 0,
            "maximum": 6
          },

          "week": {
            "type": "string",
            "enum": ["A", "B", "AB"]
          },

          "location": {
            "type": "object",
            "required": ["room", "building"],
            "additionalProperties": false,
            "properties": {
              "room": { "type": "string" },
              "building": { "type": "string" }
            }
          },

          "group": {
            "type": "integer"
          },

          "class_type": {
            "type": "string"
          },

          "start_time": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1440
          },

          "end_time": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1440
          },

          "sessions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["date", "location", "start_time", "end_time"],
              "additionalProperties": false,
              "properties": {
                "date": {
                  "type": "string",
                  "format": "date"
                },
                "location": {
                  "type": "object",
                  "required": ["room", "building"],
                  "additionalProperties": false,
                  "properties": {
                    "room": { "type": "string" },
                    "building": { "type": "string" }
                  }
                },
                "start_time": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 1440
                },
                "end_time": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 1440
                }
              }
            }
          }
        }
      }
    }
  }
}